<launch>
  <!-- ========================================================================
    global_grid_map.launch — 支持在线 / 离线 / 混合三种工作模式
    ========================================================================
    【模式说明】
      online  (默认): 仅订阅 /cloud_registered 实时点云流，与旧版完全兼容
      offline        : 启动时一次性加载 pcd_file 指定的 .pcd，不需要 FAST-LIO 在线
      both           : 先载入离线 PCD 作为底图，再叠加实时点云增量更新

    【典型用法】
      在线建图:
        roslaunch fast_lio_global_grid_map global_grid_map.launch

      离线分析（已有 PCD）:
        roslaunch fast_lio_global_grid_map global_grid_map.launch \
          pcd_mode:=offline \
          pcd_file:=/path/to/scans.pcd

      混合模式（PCD 底图 + 实时细化）:
        roslaunch fast_lio_global_grid_map global_grid_map.launch \
          pcd_mode:=both \
          pcd_file:=/path/to/scans.pcd
  ======================================================================== -->

  <!-- 主配置文件（可覆盖具体参数） -->
  <arg name="config_file"
       default="$(find fast_lio_global_grid_map)/config/global_grid_map.yaml" />
  <arg name="visualization_config"
       default="$(find fast_lio_global_grid_map)/config/visualization.yaml" />
  <arg name="rviz_config"
       default="$(find fast_lio_global_grid_map)/rviz/global_grid_map.rviz" />
  <arg name="open_rviz" default="false" />

  <!-- PCD 模式切换入口（覆盖 yaml 中的默认值）-->
  <!-- pcd_mode: online | offline | both -->
  <arg name="pcd_mode"     default="online" />
  <!-- pcd_file: 离线 .pcd 文件绝对路径（offline/both 模式时必填）-->
  <arg name="pcd_file"     default="" />
  <!-- pcd_frame_id: 离线 PCD 所在坐标系（通常与 map_frame 相同）-->
  <arg name="pcd_frame_id" default="camera_init" />
  <!-- pcd_body_frame: PCD 是否为雷达本体系（需做外参变换）-->
  <arg name="pcd_body_frame" default="false" />
  <!-- max_valid_z: 高度上限过滤（m），超过此高度的点不进入高程图（-999 = 不限制）-->
  <arg name="max_valid_z"    default="1.0" />

  <!-- Grid Map 构建节点 -->
  <node pkg="fast_lio_global_grid_map"
        type="global_grid_map_node"
        name="global_grid_map_node"
        output="screen">
    <rosparam command="load" file="$(arg config_file)" />
    <!-- 通过 launch arg 覆盖 PCD 相关参数，方便命令行一键切换，不改 yaml -->
    <param name="pcd_mode"       value="$(arg pcd_mode)"       />
    <param name="pcd_path"       value="$(arg pcd_file)"       />
    <param name="pcd_frame_id"   value="$(arg pcd_frame_id)"   />
    <param name="pcd_body_frame" value="$(arg pcd_body_frame)" />
    <param name="max_valid_z"    value="$(arg max_valid_z)"    />
  </node>

  <!-- Grid Map 可视化节点 -->
  <node pkg="grid_map_visualization"
        type="grid_map_visualization"
        name="grid_map_visualization"
        output="screen">
    <rosparam command="load" file="$(arg visualization_config)" />
  </node>

  <!-- 可选 RViz -->
  <node if="$(arg open_rviz)"
        pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(arg rviz_config)"
        output="screen" />
</launch>
