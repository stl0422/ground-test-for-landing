<launch>
    <arg name="traj_id" default="0"/>
    <arg name="auto_offboard" default="true" />
    
    <!-- <include file="$(find px4_sim)/launch/sim.launch" /> -->

    <node pkg="mpc_control" name="track_mpc" type="tracking_real_iros2025.py" output="screen">
        <param name="auto_offboard" value="$(arg auto_offboard)"/>

        <remap from="~odom" to="/mavros/local_position/odom" />
        <remap from="~odom_lidar" to="/Odometry" />

        <!-- <remap from="~odom" to="/Odometry" /> -->
        <!-- <remap from="~track_traj" to="/trajectory_generator_node/traj_msg" /> -->
        <remap from="~track_traj" to="/mpc_trajectory" />
    </node>
    
    <!-- <node pkg="uav_control" name="test_traj_pub" type="test_traj_pub.py" output="screen" /> -->
    <!-- <include file="$(find ius_visualization)/launch/test.launch" /> -->
    <!-- <node name="rviz_mpc" pkg="rviz" type="rviz" args="-d $(find uav_control)/launch/test_mpc_tarj.rviz"/>-->
</launch>
