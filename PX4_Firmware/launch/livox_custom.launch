<?xml version="1.0"?>
<launch>
    <!-- MAVROS posix SITL environment launch script -->
    <!-- launches MAVROS, PX4 SITL, Gazebo environment, and spawns vehicle -->
    <!-- vehicle pose -->

    <!-- vehicle model and world -->
    <arg name="est" default="ekf2"/>
    <arg name="vehicle" default="neverlost"/>

    <!--<arg name="world" default="$(find mavlink_sitl_gazebo)/worlds/crater_env.world"/>-->
    <arg name="world" default="$(find mavlink_sitl_gazebo)/worlds/nagetive_terrain.world"/>

    <!-- $(find mavlink_sitl_gazebo)/worlds/indoor.world -->
    <arg name="sdf" default="/home/fractal/PX4_Firmware/Tools/sitl_gazebo/models/neverlost_livox_custom/neverlost_livox_mid360_custom.sdf"/>
    <!-- <arg name="sdf" default="$(find mavlink_sitl_gazebo)/models/neverlost_livox_custom/neverlost_livox_mid360_custom.sdf"/> -->

    <!-- gazebo configs -->
    <arg name="gui" default="true"/>
    <arg name="debug" default="false"/>
    <arg name="verbose" default="false"/>
    <arg name="paused" default="false"/>
    <arg name="respawn_gazebo" default="false"/>
    <!-- MAVROS configs -->

    <!-- <arg name="fcu_url" default="udp://:14540@localhost:14557"/> -->
     <!-- udp://:24540@localhost:34580    xtdrone -->
    <arg name="fcu_url" default="udp://:24540@localhost:34580"/>

    <arg name="respawn_mavros" default="false"/>
    <!-- PX4 configs -->
    <arg name="interactive" default="true"/>
    <!-- PX4 SITL and Gazebo -->
    <include file="$(find px4)/launch/posix_sitl.launch">
        <!-- Spawn on a locally flat patch of the rough terrain.  The original
             (0,0) location is now intentionally uneven and can prevent stable
             arming/takeoff.  Around (1.5,-0.5) the fitted slope is ~0.013 rad
             and roughness is ~0.014 m over a 0.65 m radius patch. -->
        <arg name="x" value="1.5"/>
        <arg name="y" value="-0.5"/>
        <!-- base_link collision bottom is ~0.10 m below origin.  Use a small
             clearance above the local terrain so Gazebo can settle without
             spawning the body inside a mound. -->
        <arg name="z" value="0.16"/>
        <arg name="R" value="0"/>
        <arg name="P" value="0"/>
        <arg name="Y" value="1.57"/>
        <arg name="world" value="$(arg world)"/>
        <arg name="vehicle" value="$(arg vehicle)"/>
        <arg name="sdf" value="$(arg sdf)"/>
        <arg name="gui" value="$(arg gui)"/>
        <arg name="interactive" value="$(arg interactive)"/>
        <arg name="debug" value="$(arg debug)"/>
        <arg name="verbose" value="$(arg verbose)"/>
        <arg name="paused" value="$(arg paused)"/>
        <arg name="respawn_gazebo" value="$(arg respawn_gazebo)"/>
    </include>
    <!-- MAVROS -->
    <include file="$(find mavros)/launch/px4.launch">
        <!-- GCS link is provided by SITL -->
        <arg name="gcs_url" value=""/>
        <arg name="fcu_url" value="$(arg fcu_url)"/>
        <arg name="respawn_mavros" value="$(arg respawn_mavros)"/>
    </include>

    <!-- body_to_base_link: 将 FAST-LIO 的 IMU/body 帧对齐到 Gazebo base_link 帧（用于 RViz 可视化）
         【推导说明】
         static_transform_publisher 参数格式: x y z yaw pitch roll parent child
         → 描述 child(base_link) 帧原点在 parent(body) 帧中的位姿

         已知：
           SDF livox_base pose rpy=(π, -π/6, 0)，Gazebo 内旋 ZYX
           R_livox_in_base = Rz(0)·Ry(-π/6)·Rx(π) = [[√3/2,0,0.5],[0,-1,0],[0.5,0,-√3/2]]

           IMU 在 livox_base 内：T_imu_in_livox = (0.011, 0.02329, 0.105588)  [mid360 硬件规格]
           livox_base 相对 base_link 平移：t_livox_in_base = (0, 0, -0.045)  [SDF xyz]

           IMU(body) 在 base_link 中：
             T_body_in_base = t_livox_in_base + R_livox_in_base · T_imu_in_livox
                            = (0, 0, -0.045) + (0.0623, -0.0233, -0.0859)
                            = (0.0623, -0.0233, -0.1309)

           base_link 原点在 body 系中（TF 平移）：
             T_base_in_body = -R_livox_in_base^T · T_body_in_base
                            = (0.0115, -0.0233, -0.1446)

           base_link 方向在 body 系中（TF 旋转）：
             R_base_in_body = R_livox_in_base^T
             ZYX 欧拉角分解：yaw=0, pitch=-π/6=-0.5236, roll=-π=-3.1416 -->
    <node pkg="tf2_ros" type="static_transform_publisher" name="body_to_base_link"
          args="0.0115 -0.0233 -0.1446 0.0 -0.5236 -3.14159 body base_link" />

    <!-- livox_laser_simulation -->
    <!-- <node name="rviz" pkg="rviz" type="rviz" args="-d $(find livox_laser_simulation)/rviz/livox_simulation.rviz"/> -->
</launch>
