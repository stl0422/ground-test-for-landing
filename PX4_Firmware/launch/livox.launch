<?xml version="1.0"?>
<launch>
    <!-- MAVROS posix SITL environment launch script -->
    <!-- launches MAVROS, PX4 SITL, Gazebo environment, and spawns vehicle -->
    <!-- vehicle pose -->

    <!-- vehicle model and world -->
    <arg name="est" default="ekf2"/>
    <arg name="vehicle" default="neverlost"/>
    <!-- <arg name="world" default="$(find mavlink_sitl_gazebo)/worlds/Uworld.world"/> -->
    <arg name="world" default="/home/fractal/PX4_Firmware/Tools/sitl_gazebo/worlds/Uworld.world"/>

    <!-- $(find mavlink_sitl_gazebo)/worlds/indoor.world -->
    <arg name="sdf" default="/home/fractal/PX4_Firmware/Tools/sitl_gazebo/models/neverlost_livox_pitch30/neverlost_livox_mid360.sdf"/>
    <!-- <arg name="sdf" default="$(find mavlink_sitl_gazebo)/models/neverlost_livox_pitch30/neverlost_livox_mid360.sdf"/> -->

    <!-- gazebo configs -->
    <arg name="gui" default="true"/>
    <arg name="debug" default="false"/>
    <arg name="verbose" default="false"/>
    <arg name="paused" default="false"/>
    <arg name="respawn_gazebo" default="false"/>
    <!-- MAVROS configs -->

    <!-- <arg name="fcu_url" default="udp://:14540@localhost:14557"/> -->
     <!-- udp://:24540@localhost:34580    xtdrone -->
    <arg name="fcu_url" default="udp://:24540@localhost:34580"/>

    <arg name="respawn_mavros" default="false"/>
    <!-- PX4 configs -->
    <arg name="interactive" default="true"/>
    <!-- PX4 SITL and Gazebo -->
    <include file="$(find px4)/launch/posix_sitl.launch">
        <arg name="x" default="2.5"/> <!--2.5-->
        <arg name="y" default="1.04"/> <!--0.9-->
        <arg name="z" default="0.1"/>
        <arg name="R" default="0"/>
        <arg name="P" default="0"/>
        <arg name="Y" default="1.57"/>
        <arg name="world" value="$(arg world)"/>
        <arg name="vehicle" value="$(arg vehicle)"/>
        <arg name="sdf" value="$(arg sdf)"/>
        <arg name="gui" value="$(arg gui)"/>
        <arg name="interactive" value="$(arg interactive)"/>
        <arg name="debug" value="$(arg debug)"/>
        <arg name="verbose" value="$(arg verbose)"/>
        <arg name="paused" value="$(arg paused)"/>
        <arg name="respawn_gazebo" value="$(arg respawn_gazebo)"/>
    </include>
    <!-- MAVROS -->
    <include file="$(find mavros)/launch/px4.launch">
        <!-- GCS link is provided by SITL -->
        <arg name="gcs_url" value=""/>
        <arg name="fcu_url" value="$(arg fcu_url)"/>
        <arg name="respawn_mavros" value="$(arg respawn_mavros)"/>
    </include>
    <!-- livox_laser_simulation -->
    <!-- <node name="rviz" pkg="rviz" type="rviz" args="-d $(find livox_laser_simulation)/rviz/livox_simulation.rviz"/> -->
</launch>
